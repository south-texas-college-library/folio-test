{
  "displayName": "Collection - Inventory Search",
  "description": "This report can search for item records within a call number range and that may contain optional subject terms.",
  "instructions": "Input the optional call number range and subject(s) for items you would like to search for.\n\nTo search for multiple subjects, type OR between each subject.\n\nTo exclude a subject, type - before the subject.",
  "parameters": [
    {
      "name": "start_cn",
      "displayName": "Start Call Number",
      "type": "text",
      "required": false
    },
    {
      "name": "end_cn",
      "displayName": "End Call Number",
      "type": "text",
      "required": false
    },
    {
      "name": "subject",
      "displayName": "Subject",
      "type": "text",
      "required": false
    },
    {
      "name": "material_type",
      "displayName": "Material Type",
      "type": "text",
      "required": false,
      "default": "All",
      "controlled.options": [
        "All",
        "2HR-ITEM",
        "3HR-ITEM",
        "4HR-ITEM",
        "2DAY-ITEM",
        "3DAY-ITEM",
        "7DAY-ITEM",
        "28DAY-ITEM",
        "AV-ITEM",
        "BOOK",
        "CLE-ITEM",
        "DAYUSE-ITEM",
        "EBOOK",
        "ILL-ITEM",
        "OTHER",
        "RSV-ITEM",
        "SEM-ITEM",
        "SEMEXTEND-ITEM",
        "SERIAL"
      ]
    },
    {
      "name": "item_campus",
      "displayName": "Item Campus",
      "type": "text",
      "required": false,
      "default": "All",
      "controlled.options": [
        "All",
        "Mid-Valley",
        "HSP",
        "Online",
        "Pecan",
        "RCPSE",
        "Starr County",
        "Technology"
      ]
    },
    {
      "name": "item_department",
      "displayName": "Item Department",
      "type": "text",
      "required": false,
      "default": "All",
      "controlled.options": ["All", "CLE", "Library", "Open Labs"]
    }
  ]
}
